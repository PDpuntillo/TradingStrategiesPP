# ===== Frontend env vars =====
# Vite carga variables que empiezan con VITE_* en build time.

# URL base del backend en PROD (sin barra al final, incluye /api).
# Ej: VITE_API_BASE_URL=https://tradingstrategys-backend.onrender.com/api
#
# En DEV no la pongas — el cliente cae a "/api" y Vite proxea a localhost:8000
# (ver vite.config.js).
VITE_API_BASE_URL=
