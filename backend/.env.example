# ===== Google Sheets API =====
# Obtener en: https://console.cloud.google.com/apis/credentials
GOOGLE_SHEETS_API_KEY=AIzaSy_REEMPLAZAR_CON_TU_API_KEY

# Spreadsheet IDs (uno por ticker). El ID está en la URL:
# https://docs.google.com/spreadsheets/d/{ESTE_ES_EL_ID}/edit
SPREADSHEET_ID_GGAL=1AbC_REEMPLAZAR_ggal
SPREADSHEET_ID_YPF=1AbC_REEMPLAZAR_ypf
SPREADSHEET_ID_PAMP=1AbC_REEMPLAZAR_pamp

# ===== FastAPI Config =====
APP_NAME=Trading Strategy Analyzer
APP_VERSION=0.1.0
DEBUG=True
HOST=127.0.0.1
PORT=8000

# CORS (frontend URLs permitidas)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===== Cache =====
CACHE_TTL_SECONDS=300
